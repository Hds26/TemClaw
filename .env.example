# Agent Template - Environment Variables
# Copy this file to .env and fill in your values.

# Backend server port (default: 8000)
# BACKEND_PORT=8000

# Frontend dev server port (default: 3000)
# FRONTEND_PORT=3000

# Optional: pre-seed a default provider via env vars instead of the UI.
# These are picked up on first startup only if no providers exist in the DB.
# DEFAULT_PROVIDER_NAME=OpenAI
# DEFAULT_PROVIDER_TYPE=openai
# DEFAULT_PROVIDER_API_KEY=sk-...
# DEFAULT_PROVIDER_BASE_URL=https://api.openai.com/v1
# DEFAULT_PROVIDER_MODEL=gpt-4o-mini
